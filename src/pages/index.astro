---
export const prerender = true;
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>CapyStudio</title>
    <meta name="description" content="CapyStudio — a creative studio that builds things." />
  </head>
  <body class="bg-neutral-950 text-neutral-100 min-h-screen flex flex-col font-sans antialiased">

    <!-- Header -->
    <header class="px-6 py-5 flex items-center justify-between border-b border-neutral-800">
      <a href="/" class="flex items-center gap-2.5 group">
        <img src="/logo.jpg" alt="CapyStudio" width="36" height="36" class="rounded-md" />
        <span class="text-base font-semibold tracking-tight text-neutral-100 group-hover:text-white transition-colors">
          CapyStudio
        </span>
      </a>
      <nav class="hidden sm:flex items-center gap-6 text-sm text-neutral-400">
        <a href="/work" class="hover:text-neutral-100 transition-colors">Work</a>
        <a href="#about" class="hover:text-neutral-100 transition-colors">About</a>
        <a href="#contact" class="hover:text-neutral-100 transition-colors">Contact</a>
      </nav>
    </header>

    <!-- Hero -->
    <main class="flex-1 flex items-center justify-center px-6 py-24">
      <div class="max-w-2xl w-full">
        <p class="text-sm font-medium text-amber-400 tracking-widest uppercase mb-6">
          Creative Studio
        </p>
        <h1 class="text-5xl sm:text-6xl font-bold tracking-tight text-neutral-100 leading-tight mb-6">
          We build things<br />
          <span class="text-neutral-500">worth building.</span>
        </h1>
        <p class="text-lg text-neutral-400 leading-relaxed mb-10 max-w-lg">
          CapyStudio crafts thoughtful digital products — from concept to launch,
          with care for every detail.
        </p>
        <div class="flex items-center gap-4">
          <a
            href="/work"
            class="inline-flex items-center gap-2 bg-amber-400 text-neutral-950 text-sm font-semibold px-5 py-2.5 rounded-lg hover:bg-amber-300 transition-colors"
          >
            See our work
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href="#contact"
            class="inline-flex items-center text-sm font-medium text-neutral-400 hover:text-neutral-100 transition-colors"
          >
            Get in touch
          </a>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="px-6 py-5 border-t border-neutral-800 flex flex-col sm:flex-row items-center justify-between gap-2 text-sm text-neutral-500">
      <span>© {new Date().getFullYear()} CapyStudio. All rights reserved.</span>
      <span class="text-neutral-700">Built with Astro</span>
    </footer>

  </body>
</html>
