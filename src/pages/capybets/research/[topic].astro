---
import '../../../styles/global.css';
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');
Astro.response.headers.set('CDN-Cache-Control', 'no-store');
Astro.response.headers.set('Vercel-CDN-Cache-Control', 'no-store');

const { topic } = Astro.params;

if (!topic) return Astro.redirect("/capybets/research");

const TREE_URL = "https://api.github.com/repos/CapyStudio/CapyBets/git/trees/main?recursive=1";
const res = await fetch(TREE_URL);
const data = await res.json();

const digestFiles: string[] = (data.tree ?? [])
  .map((f: { path: string }) => f.path)
  .filter((p: string) => /^daily-digests\/.+\/.+\.md$/.test(p));

const entries: { date: string; path: string }[] = [];
for (const path of digestFiles) {
  const parts = path.split("/");
  if (parts[1] !== topic) continue;
  const filename = parts[2];
  const date = filename.replace(/^.+?-(\d{4}-\d{2}-\d{2})\.md$/, "$1");
  entries.push({ date, path });
}

if (entries.length === 0) return Astro.redirect("/capybets/research");

const label = topic.replace(/-/g, " ").replace(/\b\w/g, (c: string) => c.toUpperCase());
const digests = [...entries].sort((a, b) => b.date.localeCompare(a.date));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{label} — CapyBets Research</title>
    <meta name="description" content={`Daily digests for ${label}`} />
  </head>
  <body class="bg-neutral-950 text-neutral-100 min-h-screen flex flex-col font-sans antialiased">

    <!-- Header -->
    <header class="px-6 py-5 flex items-center justify-between border-b border-neutral-800">
      <a href="/" class="flex items-center gap-2.5 group">
        <img src="/logo.jpg" alt="CapyStudio" width="36" height="36" class="rounded-md" />
        <span class="text-base font-semibold tracking-tight text-neutral-100 group-hover:text-white transition-colors">
          CapyStudio
        </span>
      </a>
      <nav class="hidden sm:flex items-center gap-6 text-sm text-neutral-400">
        <a href="/#work" class="hover:text-neutral-100 transition-colors">Work</a>
        <a href="/#about" class="hover:text-neutral-100 transition-colors">About</a>
        <a href="/#contact" class="hover:text-neutral-100 transition-colors">Contact</a>
      </nav>
    </header>

    <!-- Main -->
    <main class="flex-1 px-6 py-16 max-w-3xl mx-auto w-full">
      <nav class="flex items-center gap-2 text-sm text-neutral-500 mb-8">
        <a href="/capybets/research" class="hover:text-amber-400 transition-colors">Research</a>
        <span>/</span>
        <span class="text-neutral-300">{label}</span>
      </nav>

      <p class="text-sm font-medium text-amber-400 tracking-widest uppercase mb-4">
        CapyBets Research
      </p>
      <h1 class="text-4xl font-bold tracking-tight text-neutral-100 mb-3">
        {label}
      </h1>
      <p class="text-neutral-500 mb-10">
        {digests.length} {digests.length === 1 ? "digest" : "digests"}
      </p>

      <ul class="space-y-3">
        {digests.map(({ date }) => (
          <li>
            <a
              href={`/capybets/research/${topic}/${date}`}
              class="flex items-center justify-between border border-neutral-800 rounded-lg px-5 py-4 hover:border-neutral-600 hover:bg-neutral-900 transition-all group"
            >
              <span class="text-neutral-100 font-medium group-hover:text-amber-400 transition-colors">
                {date}
              </span>
              <svg class="text-neutral-600 group-hover:text-amber-400 transition-colors" width="16" height="16" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </main>

    <!-- Footer -->
    <footer class="px-6 py-5 border-t border-neutral-800 flex flex-col sm:flex-row items-center justify-between gap-2 text-sm text-neutral-500">
      <span>© {new Date().getFullYear()} CapyStudio. All rights reserved.</span>
      <span class="text-neutral-700">Built with Astro</span>
    </footer>

  </body>
</html>
