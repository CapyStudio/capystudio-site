---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>CapyStudio — Coming Soon</title>
    <meta name="description" content="Something is cooking at CapyStudio." />
  </head>
  <body class="bg-neutral-950 text-neutral-100 min-h-screen flex flex-col items-center justify-center px-6">
    <div class="flex flex-col items-center text-center max-w-md">
      <img src="/logo.jpg" alt="CapyStudio" width="80" height="80" class="rounded-2xl mb-8" />
      <p class="text-sm font-medium text-amber-400 tracking-widest uppercase mb-4">
        Let us cook
      </p>
      <h1 class="text-4xl font-bold tracking-tight text-neutral-100 mb-4">
        Let us cook.
      </h1>
      <p class="text-neutral-400 leading-relaxed">
        We're working on something worth showing. Check back soon.
      </p>
      <a href="/" class="mt-8 text-sm text-neutral-500 hover:text-neutral-300 transition-colors">
        ← Back home
      </a>
    </div>
  </body>
</html>
