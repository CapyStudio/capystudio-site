{
  "redirects": [
    {
      "source": "/",
      "has": [{"type": "host", "value": "capybets.capystudio.co"}],
      "destination": "https://capybets.capystudio.co/capybets",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/capybets/research(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
